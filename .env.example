# Copy to .env and fill in real values. Never commit .env.

# Database
POSTGRES_USER=trama
POSTGRES_PASSWORD=trama
POSTGRES_DB=trama
DATABASE_URL=postgresql://trama:trama@localhost:5432/trama

# LLM provider for parsing fallback.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=REPLACE_ME

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
# CORS_ORIGINS=http://localhost:5173  # dev only; prod must set its real origin(s)

# Session
# COOKIE_SECURE=true  # required for any non-localhost deploy
# SESSION_TTL_DAYS=30

# Storage
# STORAGE_PATH=./storage
